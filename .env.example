# Google AI Studio free-tier key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-free-gemini-key

# Postgres connection string.
# On Vercel: provision Neon from the Marketplace and it injects this automatically.
# Locally: paste your Neon connection string (or any Postgres URL).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
